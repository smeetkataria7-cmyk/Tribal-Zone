{% comment %} TribalZone Redesign — product-card-grid.liquid {% endcomment %}
{%- assign img_url = product.featured_image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}

<style>
.tz-card {
  background: #fff;
  border: 1px solid #ececec;
  border-radius: 12px;
  overflow: hidden;
  transition: box-shadow .25s, transform .25s;
  cursor: pointer;
  display: block;
  text-decoration: none;
  color: inherit;
  font-family: var(--tz-sans, 'Inter', sans-serif);
}
.tz-card:hover {
  box-shadow: 0 8px 32px rgba(0,0,0,.11);
  transform: translateY(-3px);
}
.tz-card-img {
  position: relative;
  overflow: hidden;
  aspect-ratio: 1;
  background: #f8f4ef;
}
.tz-card-img img {
  width: 100%; height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .5s;
}
.tz-card:hover .tz-card-img img { transform: scale(1.05); }
.tz-card-badge {
  position: absolute; top: 8px; left: 8px;
  font-size: 10px; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  padding: 3px 8px; border-radius: 3px;
}
.tz-badge-sale { background: #e74c3c; color: #fff; }
.tz-badge-new { background: #b8913a; color: #fff; }
.tz-badge-out { background: #888; color: #fff; }
.tz-card-atb {
  position: absolute; bottom: 0; left: 0; right: 0;
  background: rgba(28,28,28,.9); color: #fff;
  font-size: 11px; letter-spacing: 0.1em;
  text-transform: uppercase; font-weight: 600;
  padding: 11px; text-align: center;
  transform: translateY(100%);
  transition: transform .28s ease;
}
.tz-card:hover .tz-card-atb { transform: translateY(0); }
.tz-card-info { padding: 12px 12px 14px; }
.tz-card-cat {
  font-size: 10.5px; color: #888;
  text-transform: uppercase; letter-spacing: 0.08em;
  margin-bottom: 3px;
}
.tz-card-name {
  font-size: 13.5px; font-weight: 500;
  line-height: 1.35; margin-bottom: 7px;
  color: #1c1c1c;
}
.tz-card-stars {
  color: #b8913a; font-size: 11px;
  letter-spacing: 1px; margin-bottom: 7px;
}
.tz-card-price { display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }
.tz-price-now { font-size: 14.5px; font-weight: 700; color: #1c1c1c; }
.tz-price-was { font-size: 12px; color: #aaa; text-decoration: line-through; }
.tz-price-off { font-size: 11.5px; color: #e74c3c; font-weight: 600; }
.tz-card-free { font-size: 11px; color: #2ecc71; margin-top: 4px; font-weight: 500; }
</style>

<a class="tz-card" href="{{ product.url }}">
  <div class="tz-card-img">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | img_url: '500x' }}"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        loading="lazy"
      />
    {% else %}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;color:#ddd;">💎</div>
    {% endif %}

    {% unless product.available %}
      <span class="tz-card-badge tz-badge-out">Sold Out</span>
    {% else %}
      {% if product.compare_at_price > product.price %}
        <span class="tz-card-badge tz-badge-sale">Sale</span>
      {% else %}
        <span class="tz-card-badge tz-badge-new">New</span>
      {% endif %}
    {% endunless %}

    <div class="tz-card-atb">Add to Bag</div>
  </div>

  <div class="tz-card-info">
    <div class="tz-card-cat">{{ product.type }}</div>
    <div class="tz-card-name">{{ product.title }}</div>
    <div class="tz-card-stars">★★★★★</div>
    <div class="tz-card-price">
      <span class="tz-price-now">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <span class="tz-price-was">{{ product.compare_at_price | money }}</span>
        <span class="tz-price-off">
          -{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%
        </span>
      {% endif %}
    </div>
    {% if product.price >= 50000 %}
      <div class="tz-card-free">✓ Free delivery</div>
    {% endif %}
  </div>
</a>
