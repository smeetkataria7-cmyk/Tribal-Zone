{% comment %} TribalZone Redesign — product-card-grid.liquid {% endcomment %}

<style>
  .pcard {
    background: #fff; border: none;
    overflow: hidden; transition: box-shadow .25s, transform .25s;
    cursor: pointer; display: block; color: inherit; text-decoration: none;
    scroll-snap-align: start; flex-shrink: 0;
  }
  .pcard:hover { box-shadow: 0 8px 24px rgba(0,0,0,.1); transform: translateY(-2px); }

  .pcard-img {
    position: relative; aspect-ratio: 4/5; overflow: hidden; background: #fdf9f4;
  }
  .pcard-img img.i1 { width: 100%; height: 100%; object-fit: cover; transition: opacity .4s, transform .5s; }
  .pcard-img img.i2 { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity .4s; }
  .pcard:hover .i1 { opacity: 0; transform: scale(1.06); }
  .pcard:hover .i2 { opacity: 1; }

  .pcard-badge {
    display: inline-block; margin-bottom: 8px;
    font-size: 10px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 4px 12px 4px 8px; border-radius: 0;
    background: linear-gradient(100deg, #d11473 0%, #f2157b 50%, #f5488e 100%);
    color: #ffffff;
    clip-path: polygon(0 0, 100% 0, calc(100% - 8px) 50%, 100% 100%, 0 100%);
  }

  .pcard-wish {
    position: absolute; top: 10px; right: 10px;
    background: rgba(255,255,255,.9); border: none; width: 32px; height: 32px;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 15px; cursor: pointer; transition: all .2s; color: #888;
    box-shadow: 0 2px 8px rgba(0,0,0,.1);
  }
  .pcard-wish:hover { color: #ED1A43; transform: scale(1.12); }

  .pcard-atb {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: rgba(18,1,1,.92); color: #fff; font-size: 11px;
    letter-spacing: 0.12em; text-transform: uppercase; font-weight: 600;
    padding: 12px; text-align: center;
    transform: translateY(100%); transition: transform .28s ease;
  }
  .pcard:hover .pcard-atb { transform: translateY(0); }

  .pcard-info { padding: 13px 14px 16px; display: flex; flex-direction: column; }
  .pcard-cat { display: none; }
  .pcard-name {
    font-size: 13.5px; font-weight: 400; line-height: 1.4; min-height: calc(1.4em * 2);
    margin-bottom: 8px; color: #120101; text-decoration: none;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  .pcard-price { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; margin-bottom: 2px; }
  .p-now { font-size: 16px; font-weight: 600; color: #7a1f3d; line-height: 1; }
  .p-meta { display: contents; }
  .p-was { font-size: 12.5px; color: #999; text-decoration: line-through; }
  .p-off { font-size: 11px; color: #fff; font-weight: 600; background: #4caf50; padding: 4px 10px; border-radius: 50px; }

  .pcard-stars { color: #f5a623; font-size: 11px; display: flex; align-items: center; gap: 5px; order: 10; }
  .pcard-stars span { color: #888; font-size: 11px; }

  .pcard-free { display: none; }
  .pcard-offer { display: none; }
</style>

<a class="pcard" href="{{ product.url }}"
   data-tags="{{ product.tags | join: '||' | downcase }}"
   data-type="{{ product.type | downcase }}"
   data-price="{{ product.price }}"
   data-available="{{ product.available }}"
   data-onsale="{% if product.compare_at_price > product.price %}true{% else %}false{% endif %}">
  <div class="pcard-img">
    {% if product.featured_image %}
      <img
        class="i1"
        src="{{ product.featured_image | img_url: '500x' }}"
        alt="{{ product.featured_image.alt | escape | default: product.title }}"
        loading="lazy"
      />
      {% if product.images[1] %}
        <img
          class="i2"
          src="{{ product.images[1] | img_url: '500x' }}"
          alt="hover"
        />
      {% else %}
        <img class="i2" src="{{ product.featured_image | img_url: '500x' }}" alt="hover" />
      {% endif %}
    {% else %}
      <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;color:#ddd;">💎</div>
    {% endif %}

    <button class="pcard-wish" onclick="event.preventDefault();toggleWish(this)">♡</button>
    <div class="pcard-atb">Add to Bag</div>
  </div>

  <div class="pcard-info">
    {% unless product.available %}
      <span class="pcard-badge">Sold Out</span>
    {% else %}
      {% if product.compare_at_price > product.price %}
        <span class="pcard-badge b-sale">Sale</span>
      {% else %}
        <span class="pcard-badge b-new">New</span>
      {% endif %}
    {% endunless %}

    <div class="pcard-cat">{{ product.type }}</div>
    <div class="pcard-name">{{ product.title }}</div>
    <div class="pcard-price">
      <span class="p-now">{{ product.price | money }}</span>
      {% if product.compare_at_price > product.price %}
        <div class="p-meta">
          <span class="p-was">{{ product.compare_at_price | money }}</span>
          <span class="p-off">{{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price | round }}% OFF</span>
        </div>
      {% endif %}
    </div>
    <div class="pcard-stars">★★★★★ <span>(0)</span></div>

    {% if product.price >= 50000 %}
      <div class="pcard-free">✓ Free delivery</div>
    {% endif %}
  </div>
</a>

{% comment %} Randomize ratings 4-5 stars + review counts (matches static preview) {% endcomment %}
<script>
(function(){
  if (window.__tzRatingsInit) return;
  window.__tzRatingsInit = true;
  function tzRandomizeRatings(){
    document.querySelectorAll('.pcard-stars').forEach(function(el){
      if (el.dataset.tzDone) return;
      var stars = Math.random() < 0.5 ? 4 : 5;
      var reviews = Math.floor(Math.random() * (400 - 30) + 30);
      el.innerHTML = '★'.repeat(stars) + ' <span>(' + reviews + ')</span>';
      el.dataset.tzDone = '1';
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tzRandomizeRatings);
  } else {
    tzRandomizeRatings();
  }
})();
</script>
