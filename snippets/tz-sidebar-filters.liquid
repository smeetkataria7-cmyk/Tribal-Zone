{% comment %}
  TribalZone — tz-sidebar-filters.liquid
  Native Shopify faceted filtering (multi-select). Requires the free
  "Search & Discovery" app to define which filters appear (collection.filters).
{% endcomment %}

<div class="tz-sb-head">
  <span>Filters</span>
  <a href="{{ collection.url }}" class="tz-clear">Clear All</a>
</div>

{% if collection.filters.size > 0 %}

  {%- comment -%} Active filter chips (multi-select aware) {%- endcomment -%}
  {%- assign has_active = false -%}
  {%- for filter in collection.filters -%}
    {%- if filter.active_values.size > 0 -%}{%- assign has_active = true -%}{%- endif -%}
    {%- if filter.type == 'price_range' -%}
      {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}{%- assign has_active = true -%}{%- endif -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if has_active -%}
    <div class="tz-active-chips" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px;">
      {%- for filter in collection.filters -%}
        {%- for value in filter.active_values -%}
          <a class="tz-atag" href="{{ value.url_to_remove }}" style="display:inline-flex;align-items:center;gap:5px;background:#fff0f5;border:1px solid #f5488e;font-size:12px;padding:4px 10px;border-radius:20px;text-decoration:none;color:#120101;">{{ value.label }} <span>×</span></a>
        {%- endfor -%}
        {%- if filter.type == 'price_range' -%}
          {%- if filter.min_value.value != blank or filter.max_value.value != blank -%}
            <a class="tz-atag" href="{{ filter.url_to_remove }}" style="display:inline-flex;align-items:center;gap:5px;background:#fff0f5;border:1px solid #f5488e;font-size:12px;padding:4px 10px;border-radius:20px;text-decoration:none;color:#120101;">{{ filter.label }} <span>×</span></a>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  <form method="get" class="tz-filter-form">
    {%- comment -%} Preserve current sort when a filter changes {%- endcomment -%}
    {%- if collection.sort_by != blank -%}
      <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
    {%- endif -%}

    {% for filter in collection.filters %}
      <div class="tz-fg open">
        <div class="tz-fg-head" onclick="this.closest('.tz-fg').classList.toggle('open')">
          <span>{{ filter.label }}</span>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="m6 9 6 6 6-6"/></svg>
        </div>
        <div class="tz-fg-body">
          {% case filter.type %}

            {% when 'list', 'boolean' %}
              {% for value in filter.values %}
                <label class="tz-opt">
                  <input
                    type="checkbox"
                    name="{{ value.param_name }}"
                    value="{{ value.value }}"
                    {% if value.active %}checked{% endif %}
                    {% if value.count == 0 and value.active == false %}disabled{% endif %}
                    onchange="this.form.submit()">
                  <span class="tz-box"></span>
                  <span class="tz-opt-lbl">{{ value.label }}</span>
                  <span class="tz-opt-cnt">({{ value.count }})</span>
                </label>
              {% endfor %}

            {% when 'price_range' %}
              <div class="tz-price-inputs">
                <input class="tz-pi" type="number" inputmode="decimal" min="0"
                  name="{{ filter.min_value.param_name }}"
                  value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                  placeholder="₹ Min">
                <input class="tz-pi" type="number" inputmode="decimal" min="0"
                  name="{{ filter.max_value.param_name }}"
                  value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                  placeholder="₹ Max">
              </div>
              <button type="submit" class="tz-ptag" style="margin-top:10px;">Apply price</button>

          {% endcase %}
        </div>
      </div>
    {% endfor %}
  </form>

{% else %}

  <p style="font-size:12.5px;color:#888;line-height:1.6;padding:8px 0;">
    No filters configured yet. Add filters in the <b>Search &amp; Discovery</b> app
    (Filters tab) and they'll appear here automatically.
  </p>

{% endif %}
