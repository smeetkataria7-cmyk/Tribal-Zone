<style>
  :root {
    --tz-gold: #f2157b; --tz-gold-lt: #f5488e; --tz-dark: #120101;
    --tz-mid: #3a3a3a; --tz-muted: #888; --tz-border: #e8e8e8; --tz-cream: #fdf9f4;
  }
  .tzs-wrap { font-family: 'Poppins', system-ui, sans-serif; color: var(--tz-dark); max-width: 1400px; margin: 0 auto; padding: 0 20px 60px; }

  /* Header */
  .tzs-head { text-align: center; padding: 44px 20px 30px; border-bottom: 1px solid var(--tz-border); margin-bottom: 30px; background: var(--tz-cream); border-radius: 0 0 20px 20px; }
  .tzs-eyebrow { font-size: 12px; letter-spacing: 0.28em; color: var(--tz-gold); text-transform: uppercase; font-weight: 600; margin-bottom: 10px; }
  .tzs-title { font-family: 'Cormorant Garamond', Georgia, serif; font-size: clamp(28px, 3.5vw, 42px); font-weight: 400; margin: 0 0 6px; line-height: 1.15; }
  .tzs-title em { color: var(--tz-gold); font-style: italic; }
  .tzs-count { font-size: 14px; color: var(--tz-muted); margin: 0 0 22px; }

  /* Search form */
  .tzs-form { max-width: 560px; margin: 0 auto; display: flex; gap: 8px; background: #fff; border: 1px solid var(--tz-border); border-radius: 50px; padding: 6px 6px 6px 20px; box-shadow: 0 4px 14px rgba(0,0,0,.04); }
  .tzs-form input { flex: 1; border: none; background: transparent; font-family: inherit; font-size: 14.5px; color: var(--tz-dark); outline: none; }
  .tzs-form input::placeholder { color: var(--tz-muted); }
  .tzs-form button { background: var(--tz-gold); color: #fff; border: none; padding: 12px 26px; border-radius: 50px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; font-size: 12px; cursor: pointer; transition: background .2s; }
  .tzs-form button:hover { background: var(--tz-gold-lt); }

  /* Product grid */
  .tzs-products { display: grid; grid-template-columns: repeat(4, 1fr); gap: 22px 18px; margin-top: 6px; }
  @media (max-width: 1024px) { .tzs-products { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 720px) { .tzs-products { grid-template-columns: repeat(2, 1fr); gap: 14px 10px; } }

  /* Empty / no results */
  .tzs-empty { text-align: center; padding: 60px 20px; }
  .tzs-empty-h { font-family: 'Cormorant Garamond', Georgia, serif; font-size: 28px; font-weight: 400; margin: 0 0 8px; }
  .tzs-empty-p { font-size: 14px; color: var(--tz-muted); margin: 0 0 22px; max-width: 460px; margin-inline: auto; line-height: 1.7; }
  .tzs-empty-cta { display: inline-block; background: var(--tz-gold); color: #fff; padding: 12px 28px; border-radius: 50px; text-decoration: none; font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600; transition: background .2s; }
  .tzs-empty-cta:hover { background: var(--tz-gold-lt); }

  /* Suggestion chips */
  .tzs-chips { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 22px; }
  .tzs-chip { border: 1px solid var(--tz-border); background: #fff; color: var(--tz-mid); font-size: 12.5px; padding: 8px 16px; border-radius: 50px; text-decoration: none; transition: all .2s; }
  .tzs-chip:hover { border-color: var(--tz-gold); color: var(--tz-gold); background: #fff0f8; }

  /* Pagination */
  .tzs-pg { display: flex; justify-content: center; gap: 6px; margin-top: 40px; flex-wrap: wrap; }
  .tzs-pg-btn { border: 1px solid var(--tz-border); background: #fff; color: var(--tz-mid); font-size: 13px; padding: 9px 14px; border-radius: 8px; text-decoration: none; transition: all .2s; min-width: 40px; text-align: center; }
  .tzs-pg-btn:hover { border-color: var(--tz-gold); color: var(--tz-gold); }
  .tzs-pg-btn.on { background: var(--tz-gold); color: #fff; border-color: var(--tz-gold); }
</style>

{% paginate search.results by 40 %}

<div class="tzs-wrap">

  <div class="tzs-head">
    <div class="tzs-eyebrow">Search</div>
    {% if search.performed %}
      <h1 class="tzs-title">Results for <em>"{{ search.terms | escape }}"</em></h1>
      <p class="tzs-count">{{ search.results_count }} {% if search.results_count == 1 %}product found{% else %}products found{% endif %}</p>
    {% else %}
      <h1 class="tzs-title">Search Our <em>Collection</em></h1>
      <p class="tzs-count">Find your perfect piece — over 1500 styles to choose from.</p>
    {% endif %}

    <form action="/search" method="get" role="search" class="tzs-form">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search earrings, necklaces, zodiac..." aria-label="Search">
      <button type="submit">Search</button>
    </form>
  </div>

  {% if search.performed %}
    {% if search.results_count > 0 %}
      <div class="tzs-products">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}
            {% render 'product-card-grid', product: item %}
          {% endif %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="tzs-pg">
          {% if paginate.previous %}<a href="{{ paginate.previous.url }}" class="tzs-pg-btn">← Prev</a>{% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" class="tzs-pg-btn">{{ part.title }}</a>
            {% else %}
              {% if part.title == paginate.current_page %}
                <span class="tzs-pg-btn on">{{ part.title }}</span>
              {% else %}
                <span class="tzs-pg-btn">{{ part.title }}</span>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% if paginate.next %}<a href="{{ paginate.next.url }}" class="tzs-pg-btn">Next →</a>{% endif %}
        </div>
      {% endif %}
    {% else %}
      <div class="tzs-empty">
        <h2 class="tzs-empty-h">No results found</h2>
        <p class="tzs-empty-p">We couldn't find anything matching <b>"{{ search.terms | escape }}"</b>. Try a different keyword, or browse our popular categories below.</p>
        <a href="/collections/all" class="tzs-empty-cta">Browse All Products →</a>
        <div class="tzs-chips">
          <a href="/collections/earrings" class="tzs-chip">Earrings</a>
          <a href="/collections/necklace" class="tzs-chip">Necklaces</a>
          <a href="/collections/bracelets" class="tzs-chip">Bracelets</a>
          <a href="/collections/elegant-rings" class="tzs-chip">Rings</a>
          <a href="/collections/zodiac-pendants" class="tzs-chip">Zodiac</a>
          <a href="/collections/sale" class="tzs-chip">Sale</a>
        </div>
      </div>
    {% endif %}
  {% endif %}

</div>

{% endpaginate %}
