<script>
  function openMob(){ document.getElementById('mobOverlay').classList.add('on'); document.getElementById('mobDrawer').classList.add('on'); }
  function closeMob(){ document.getElementById('mobOverlay').classList.remove('on'); document.getElementById('mobDrawer').classList.remove('on'); }
  function tzMobAcc(head) {
    var body = head.nextElementSibling;
    var arrow = head.querySelector('.mob-acc-arrow');
    var isOpen = body.classList.toggle('open');
    if (arrow) arrow.style.transform = isOpen ? 'rotate(180deg)' : '';
  }
</script>


{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo (optional, overrides default)" },
    { "type": "link_list", "id": "main_linklist", "label": "Menu (not used by fixed nav)" },
    { "type": "header", "content": "Announcement bar (rotating messages)" },
    { "type": "text", "id": "announce_1", "label": "Message 1", "default": "FREE SHIPPING ON ORDER ABOVE 499" },
    { "type": "text", "id": "announce_2", "label": "Message 2", "default": "FREE BAG CHARM ON ORDER ABOVE 499" },
    { "type": "text", "id": "announce_3", "label": "Message 3", "default": "FREE WALLET ON ORDER 999" }
  ]
}
{% endschema %}
