{% comment %} TribalZone header — same on every page {% endcomment %}
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
    /* Cart & general buttons → brand pink (loads on every page, incl. cart) */
    .btn, .cart__submit, input[type="submit"].btn, .cart__submit-control {
      background: #f2157b !important; border-color: #f2157b !important; color: #fff !important;
    }
    .btn--secondary, .cart__submit-control.btn--secondary {
      background: #fff !important; color: #f2157b !important; border: 1px solid #f2157b !important;
    }
    .btn:hover, .cart__submit:hover, .cart__submit-control:hover {
      background: #f5488e !important; border-color: #f5488e !important;
    }
    /* Cart-page accent links (Continue shopping, Remove, shipping) → brand pink */
    .text-link--accent, a.text-link--accent { color: #f2157b !important; }
    .text-link--accent:hover { color: #f5488e !important; }
    :root {
      --gold:    #F2157B;
      --gold-lt: #f5488e;
      --gold-bg: #fff0f8;
      --cream:   #fdf9f4;
      --white:   #ffffff;
      --dark:    #120101;
      --navy:    #162950;
      --mid:     #3a3a3a;
      --muted:   #888888;
      --border:  #e8e8e8;
      --red:     #ED1A43;
      --green:   #27ae60;
      --serif:   'Cormorant Garamond', Georgia, serif;
      --sans:    'Poppins', system-ui, sans-serif;
      --radius:  12px;
    }
    /* ── ANNOUNCE BAR ── */
    .announce {
      background: var(--dark); color: rgba(255,255,255,.85);
      text-align: center; padding: 0 20px; font-size: 12.5px;
      letter-spacing: 0.06em; height: 38px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      font-weight: 500;
    }
    .announce-track { display: flex; flex-direction: column; height: 18px; overflow: hidden; }
    .announce-msg {
      height: 18px; display: flex; align-items: center; justify-content: center;
      gap: 8px; flex-shrink: 0; white-space: nowrap;
      animation: aRoll 12s infinite;
    }
    .announce b { color: var(--gold-lt); }
    .announce .sep { opacity: .35; margin: 0 6px; }
    @keyframes aRoll {
      0%,28%  { transform: translateY(0); }
      33%,61% { transform: translateY(-18px); }
      66%,94% { transform: translateY(-36px); }
      100%    { transform: translateY(0); }
    }

    /* ── HEADER ── */
    .hdr {
      position: sticky; top: 0; z-index: 300;
      background: rgba(255,255,255,.98); backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 2px 12px rgba(0,0,0,.04);
    }
    .hdr-row {
      max-width: 1400px; margin: 0 auto; padding: 0 32px;
      height: 120px; display: flex; align-items: center; gap: 0;
    }
    .hdr-logo { flex-shrink: 0; display: flex; align-items: center; margin-right: 32px; }
    .hdr-logo img { height: 80px; width: auto; display: block; }
    .hdr-search { display: none; }
    .hdr-right { display: flex; align-items: center; gap: 2px; flex-shrink: 0; margin-left: auto; }
    .hdr-icon {
      background: none; border: none; padding: 9px; color: var(--mid);
      display: flex; align-items: center; position: relative;
      border-radius: 50%; transition: color .2s, background .2s;
    }
    .hdr-icon:hover { color: var(--gold); background: var(--gold-bg); }
    .cart-toggle {
      display: flex; align-items: center; gap: 7px;
      padding: 9px 18px; background: var(--dark); color: #fff;
      border: none; border-radius: 50px; font-size: 12px;
      letter-spacing: 0.05em; text-transform: uppercase; font-weight: 500;
      transition: background .2s; position: relative; margin-left: 6px;
    }
    .cart-toggle:hover { background: var(--gold); }
    .cart-toggle .bdg {
      background: var(--gold); color: #fff; font-size: 9px; font-weight: 700;
      width: 16px; height: 16px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; flex-shrink: 0;
    }
    .cart-toggle:hover .bdg { background: #fff; color: var(--gold); }
    .ham-btn { display: none; background: none; border: none; padding: 8px; color: var(--dark); }

    /* ── NAV ── */
    .nav { flex: 1; }
    .nav-inner { display: flex; align-items: center; height: 100%; }
    .nav-item { position: relative; }
    .nav-lnk {
      display: block; padding: 0 16px; font-size: 16px;
      font-weight: 600; color: var(--mid); transition: color .2s;
      white-space: nowrap; line-height: 120px;
    }
    .nav-lnk:hover { color: var(--dark); }
    .nav-lnk.active { color: var(--dark); border-bottom: 2px solid var(--gold); }
    .nav-lnk.sale { color: var(--red); font-weight: 600; }
    .nav-item:hover .nav-drop { display: block; }
    .nav-drop {
      display: none; position: absolute; top: 100%; left: 0;
      background: #fff; border: 1px solid var(--border);
      box-shadow: 0 12px 36px rgba(0,0,0,.1); min-width: 190px;
      border-radius: 0 0 10px 10px; z-index: 400; padding: 6px 0;
    }
    .nav-drop a {
      display: block; padding: 10px 20px; font-size: 13px;
      color: var(--mid); transition: all .15s;
    }
    .nav-drop a:hover { color: var(--gold); background: var(--gold-bg); padding-left: 26px; }
    .nav-lnk-arrow { font-size: 9px; margin-left: 4px; opacity: .6; vertical-align: middle; }

    /* ── MOBILE ACCORDION ── */
    .mob-acc-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 24px; font-size: 14px; color: var(--dark);
      border-bottom: 1px solid var(--border); cursor: pointer;
      transition: color .15s;
    }
    .mob-acc-head:hover { color: var(--gold); }
    .mob-acc-arrow { font-size: 11px; transition: transform .25s; }
    .mob-acc-body { display: none; background: #fafafa; }
    .mob-acc-body.open { display: block; }
    .mob-acc-body a {
      display: block; padding: 11px 24px 11px 36px; font-size: 13px;
      color: var(--mid); border-bottom: 1px solid var(--border); transition: color .15s;
    }
    .mob-acc-body a:hover { color: var(--gold); }

    /* ── MOBILE NAV DRAWER ── */
    .mob-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.5); z-index: 490;
    }
    .mob-overlay.on { display: block; }
    .mob-drawer {
      position: fixed; top: 0; left: -100%; bottom: 0; width: 310px;
      background: #fff; z-index: 500; padding: 0; overflow-y: auto;
      transition: left .32s cubic-bezier(.4,0,.2,1);
      box-shadow: 4px 0 32px rgba(0,0,0,.18);
    }
    .mob-drawer.on { left: 0; }
    .mob-drawer-head {
      display: flex; align-items: center; justify-content: space-between;
      padding: 18px 20px; border-bottom: 1px solid var(--border);
    }
    .mob-close { background: none; border: none; font-size: 26px; color: var(--muted); line-height: 1; }
    .mob-nav { padding: 12px 0; }
    .mob-nav a {
      display: flex; align-items: center; justify-content: space-between;
      padding: 14px 24px; font-size: 14px; color: var(--dark);
      border-bottom: 1px solid var(--border); transition: color .15s;
    }
    .mob-nav a:hover { color: var(--gold); }
    .mob-nav .sale-m { color: var(--red); font-weight: 600; }

    @media (max-width: 900px) { .nav { display:none; } .ham-btn { display:flex; } }
    @media (max-width: 600px) {
      .announce { height:48px; font-size:12px; padding:0 12px; }
      .announce-msg { font-size:12px; white-space:normal; }
      .hdr-row { padding:0 14px; gap:0; height:64px; position:relative; }
      .hdr-logo { margin:0; position:absolute; left:50%; transform:translateX(-50%); }
      .hdr-logo img { height:44px; }
      .ham-btn { position:absolute; left:14px; top:50%; transform:translateY(-50%); padding:8px; }
      .nav { display:none; }
      .hdr-right { position:absolute; right:14px; top:50%; transform:translateY(-50%); gap:6px; }
      .cart-toggle { padding:8px; font-size:0; margin-left:0; background:none; color:var(--dark); }
      .cart-toggle .bdg { position:absolute; top:0; right:0; }
    }

</style>

<!-- ANNOUNCE BAR -->
<div class="announce">
  <div class="announce-track">
    {% if section.settings.announce_1 != blank %}<div class="announce-msg">{{ section.settings.announce_1 }}</div>{% endif %}
