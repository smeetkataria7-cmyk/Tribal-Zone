<!-- MEMBER LOYALTY PROGRAM (standalone editable section) -->
<style>
  .tz-loyalty { background:linear-gradient(120deg,#c01065 0%,#f2157b 55%,#f5488e 100%); color:#fff; padding:56px 24px; }
  .tz-loy-inner { max-width:1000px; margin:0 auto; text-align:center; }
  .tz-loy-eyebrow { font-size:11px; font-weight:700; letter-spacing:.22em; text-transform:uppercase; color:#fff; opacity:.9; }
  .tz-loy-title { font-family:var(--serif,'Cormorant Garamond',Georgia,serif); font-size:clamp(30px,4vw,50px); font-weight:300; color:#fff; margin-top:8px; }
  .tz-loy-title em { font-style:italic; color:#ffe3f1; }
  .tz-loy-sub { font-size:15px; line-height:1.7; max-width:600px; margin:14px auto 0; color:#fff !important; opacity:.92; }
  .tz-loy-steps { display:grid; grid-template-columns:repeat(3,1fr); gap:24px; margin:38px 0; }
  .tz-loy-step { background:rgba(255,255,255,.12); border:1px solid rgba(255,255,255,.25); border-radius:16px; padding:26px 18px; backdrop-filter:blur(4px); }
  .tz-loy-num { width:44px; height:44px; margin:0 auto 14px; border-radius:50%; background:#fff; color:#f2157b; font-weight:700; font-size:18px; display:flex; align-items:center; justify-content:center; }
  .tz-loy-h { font-size:17px; font-weight:600; margin-bottom:6px; color:#fff !important; }
  .tz-loy-p { font-size:13.5px; opacity:.85; line-height:1.55; color:#fff !important; }
  .tz-loy-btn { display:inline-block; background:#fff; color:#f2157b; font-size:13px; font-weight:700; letter-spacing:.08em; text-transform:uppercase; padding:15px 40px; border-radius:50px; text-decoration:none; transition:transform .2s, box-shadow .2s; }
  .tz-loy-btn:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(0,0,0,.22); }
  @media(max-width:700px){ .tz-loy-steps{ grid-template-columns:1fr; gap:14px; } .tz-loyalty{ padding:40px 16px; } }
</style>

<section class="tz-loyalty">
  <div class="tz-loy-inner">
    <span class="tz-loy-eyebrow">{{ section.settings.eyebrow }}</span>
    <h2 class="tz-loy-title">{{ section.settings.title_1 }} <em>{{ section.settings.title_em }}</em></h2>
    <p class="tz-loy-sub">{{ section.settings.subtitle }}</p>
    <div class="tz-loy-steps">
      <div class="tz-loy-step"><div class="tz-loy-num">1</div><div class="tz-loy-h">{{ section.settings.step1_h }}</div><div class="tz-loy-p">{{ section.settings.step1_p }}</div></div>
      <div class="tz-loy-step"><div class="tz-loy-num">2</div><div class="tz-loy-h">{{ section.settings.step2_h }}</div><div class="tz-loy-p">{{ section.settings.step2_p }}</div></div>
      <div class="tz-loy-step"><div class="tz-loy-num">3</div><div class="tz-loy-h">{{ section.settings.step3_h }}</div><div class="tz-loy-p">{{ section.settings.step3_p }}</div></div>
    </div>
    <a href="{{ section.settings.button_link }}" class="tz-loy-btn" id="tzLoyaltyBtn" onclick="if(window.SmileUI&&window.SmileUI.openPanel){window.SmileUI.openPanel();return false;}">{{ section.settings.button_label }}</a>
  </div>
</section>

{% schema %}
{
  "name": "Loyalty Program",
  "class": "index-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Tribal Zone Rewards" },
    { "type": "text", "id": "title_1", "label": "Title (first part)", "default": "Earn Points." },
    { "type": "text", "id": "title_em", "label": "Title (italic part)", "default": "Get Rewarded." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "Join free and collect points on every order — then redeem them for discounts on your favourite pieces." },
    { "type": "header", "content": "Step 1" },
    { "type": "text", "id": "step1_h", "label": "Step 1 heading", "default": "Sign Up Free" },
    { "type": "text", "id": "step1_p", "label": "Step 1 text", "default": "Create an account in seconds and start earning right away." },
    { "type": "header", "content": "Step 2" },
    { "type": "text", "id": "step2_h", "label": "Step 2 heading", "default": "Shop & Earn" },
    { "type": "text", "id": "step2_p", "label": "Step 2 text", "default": "Collect points every time you place an order." },
    { "type": "header", "content": "Step 3" },
    { "type": "text", "id": "step3_h", "label": "Step 3 heading", "default": "Redeem & Save" },
    { "type": "text", "id": "step3_p", "label": "Step 3 text", "default": "Turn your points into discounts at checkout." },
    { "type": "header", "content": "Button" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join Rewards" },
    { "type": "url", "id": "button_link", "label": "Button link", "default": "/account" }
  ],
  "presets": [{ "name": "Loyalty Program" }]
}
{% endschema %}
