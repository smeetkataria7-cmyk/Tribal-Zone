    {%- endif -%}
  </div>
</div></section>


<!-- NEW ARRIVALS ROW -->
<section class="sec sec-cream">
  <div class="sec-inner">
    <div class="row-head">
      <div class="sec-head">
        <h2 class="sec-title">New Arrivals</h2>
      </div>
    </div>
    <div class="prod-row-wrap">
      <button class="row-arr row-prev" onclick="scrollRow('newRow',-1)">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
      </button>
      <div class="prod-row" id="newRow">
        {%- assign new_coll = collections['frontpage'] -%}
        {%- for product in new_coll.products limit: 10 -%}
          <a class="pcard" href="{{ product.url }}">
            <div class="pcard-img">
              <img class="i1" src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" loading="lazy"/>
              {%- if product.images[1] -%}<img class="i2" src="{{ product.images[1] | image_url: width: 400 }}" alt="{{ product.title }}" loading="lazy"/>{%- endif -%}
              <button class="pcard-wish" onclick="event.preventDefault();toggleWish(this)">♡</button>
              <div class="pcard-atb">Add to Cart</div>
            </div>
            <div class="pcard-info">
              {%- if product.compare_at_price > product.price -%}<span class="pcard-badge b-sale">Sale</span>{%- endif -%}
              <div class="pcard-name">{{ product.title }}</div>
              <div class="pcard-price">
                <span class="p-now">₹{{ product.price | money_without_currency }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <div class="p-meta"><span class="p-was">₹{{ product.compare_at_price | money_without_currency }}</span><span class="p-off">{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}% OFF</span></div>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      </div>
      <button class="row-arr row-next" onclick="scrollRow('newRow',1)">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
      </button>
    </div>
    <div class="row-footer">
      <a href="/collections/frontpage" class="row-view-all">View all</a>
    </div>
  </div>
</section>


