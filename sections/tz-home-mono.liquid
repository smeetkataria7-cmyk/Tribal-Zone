<!-- CATEGORY TILES (individual editable blocks) -->
{%- assign cat_count = 0 -%}
{%- for b in section.blocks -%}{%- if b.type == 'category' -%}{%- assign cat_count = cat_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
<div class="cat-tiles-wrap">
  <div class="cat-tiles">
    {%- if cat_count > 0 -%}
      {%- for block in section.blocks -%}{%- if block.type == 'category' -%}
      <a href="{{ block.settings.link }}" class="cat-tile" {{ block.shopify_attributes }}>
        <div class="cat-tile-img"><img src="{{ block.settings.image_url }}" alt="{{ block.settings.label }}" loading="lazy"/></div>
        <div class="cat-tile-label">{{ block.settings.label }}</div>
      </a>
      {%- endif -%}{%- endfor -%}
