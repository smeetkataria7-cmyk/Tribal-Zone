<!-- MONOLITHIC HOMEPAGE - All sections combined, populated product rows -->

<!-- HERO CAROUSEL (editable slides via blocks) -->
{%- assign slide_count = 0 -%}
{%- for b in section.blocks -%}{%- if b.type == 'slide' -%}{%- assign slide_count = slide_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
<section class="hero">
  <div class="hero-track" id="heroTrack">
    {%- if slide_count > 0 -%}
      {%- for block in section.blocks -%}{%- if block.type == 'slide' -%}
      <div class="hero-slide" {{ block.shopify_attributes }}>
        <div class="hero-bg" style="background-image:url('{% if block.settings.image %}{{ block.settings.image | image_url: width: 2000 }}{% else %}{{ block.settings.image_url }}{% endif %}')"></div>
        <div class="hero-overlay"></div>
        <div class="hero-content">
          {%- if block.settings.eyebrow != blank -%}<div class="hero-eyebrow">{{ block.settings.eyebrow }}</div>{%- endif -%}
          <h1 class="hero-h1">{{ block.settings.heading_1 }}{% if block.settings.heading_em != blank %}<br/><em>{{ block.settings.heading_em }}</em>{% endif %}{% if block.settings.heading_2 != blank %}<br/>{{ block.settings.heading_2 }}{% endif %}</h1>
          {%- if block.settings.desc != blank -%}<p class="hero-desc">{{ block.settings.desc }}</p>{%- endif -%}
          <div class="hero-btns">
            {%- if block.settings.btn1_label != blank -%}<a href="{{ block.settings.btn1_link }}" class="btn-fill">{{ block.settings.btn1_label }}</a>{%- endif -%}
            {%- if block.settings.btn2_label != blank -%}<a href="{{ block.settings.btn2_link }}" class="btn-outline-w">{{ block.settings.btn2_label }}</a>{%- endif -%}
          </div>
        </div>
      </div>
      {%- endif -%}{%- endfor -%}
    {%- else -%}
      <div class="hero-slide"><div class="hero-bg" style="background-image:url('https://cdn.shopify.com/s/files/1/0301/2793/files/TZHC4351-5_1.jpg?v=1780742553')"></div><div class="hero-overlay"></div><div class="hero-content"><div class="hero-eyebrow">New Arrivals — 2024</div><h1 class="hero-h1">Elevate Your<br/><em>Everyday</em><br/>with Jewellery</h1><p class="hero-desc">Handcrafted fashion accessories blending Indian tradition with modern elegance — since 2003.</p><div class="hero-btns"><a href="/collections/earrings" class="btn-fill">Shop New Arrivals →</a><a href="/collections/earrings" class="btn-outline-w">Explore All</a></div></div></div>
      <div class="hero-slide"><div class="hero-bg" style="background-image:url('https://cdn.shopify.com/s/files/1/0301/2793/files/Creative_e0be92f9-4e21-488f-9628-99cdf0fd33d8.jpg?v=1781088637')"></div><div class="hero-overlay"></div><div class="hero-content"><div class="hero-eyebrow">Limited Time Offer</div><h1 class="hero-h1">Up to<br/><em>50% Off</em><br/>Sale is Live</h1><p class="hero-desc">Shop our biggest sale of the season. Stunning earrings, necklaces &amp; more at unbeatable prices.</p><div class="hero-btns"><a href="/collections/sale" class="btn-fill">Shop the Sale →</a></div></div></div>
      <div class="hero-slide"><div class="hero-bg" style="background-image:url('https://cdn.shopify.com/s/files/1/0301/2793/files/Creative_46df76f1-5aa8-44cb-9404-46bdeed4d4a1.jpg?v=1781081928')"></div><div class="hero-overlay"></div><div class="hero-content"><div class="hero-eyebrow">Celestial Collection</div><h1 class="hero-h1">Wear Your<br/><em>Zodiac</em><br/>Story</h1><p class="hero-desc">Meaningful pendants for all 12 star signs. The perfect personalised gift for someone special.</p><div class="hero-btns"><a href="/collections/zodiac-pendants" class="btn-fill">Shop Zodiac →</a></div></div></div>
    {%- endif -%}
  </div>
  <button class="hero-arr hero-prev" onclick="heroMove(-1)"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg></button>
  <button class="hero-arr hero-next" onclick="heroMove(1)"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></button>
  <div class="hero-dots" id="heroDots">
    {%- if slide_count > 0 -%}
      {%- assign si = 0 -%}{%- for block in section.blocks -%}{%- if block.type == 'slide' -%}<div class="hero-dot {% if si == 0 %}on{% endif %}" onclick="heroGo({{ si }})"></div>{%- assign si = si | plus: 1 -%}{%- endif -%}{%- endfor -%}
    {%- else -%}
      <div class="hero-dot on" onclick="heroGo(0)"></div><div class="hero-dot" onclick="heroGo(1)"></div><div class="hero-dot" onclick="heroGo(2)"></div>
    {%- endif -%}
  </div>
</section>


<!-- VALUES MARQUEE (editable text) -->
{%- capture mq -%}{% if section.settings.marquee_1 != blank %}<span class="tz-mq-item"><span class="star">&#10022;</span> {{ section.settings.marquee_1 }}</span>{% endif %}{% if section.settings.marquee_2 != blank %}<span class="tz-mq-item"><span class="star">&#10022;</span> {{ section.settings.marquee_2 }}</span>{% endif %}{% if section.settings.marquee_3 != blank %}<span class="tz-mq-item"><span class="star">&#10022;</span> {{ section.settings.marquee_3 }}</span>{% endif %}{% if section.settings.marquee_4 != blank %}<span class="tz-mq-item"><span class="star">&#10022;</span> {{ section.settings.marquee_4 }}</span>{% endif %}{% if section.settings.marquee_5 != blank %}<span class="tz-mq-item"><span class="star">&#10022;</span> {{ section.settings.marquee_5 }}</span>{% endif %}{% if section.settings.marquee_6 != blank %}<span class="tz-mq-item"><span class="star">&#10022;</span> {{ section.settings.marquee_6 }}</span>{% endif %}{%- endcapture -%}
<div class="tz-marquee"><div class="tz-marquee-track">{{ mq }}{{ mq }}</div></div>


<!-- CATEGORY TILES (editable via blocks) -->
