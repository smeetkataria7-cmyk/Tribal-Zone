<!-- MONOLITHIC HOMEPAGE - All sections combined, populated product rows -->

<!-- HERO CAROUSEL (editable slides via blocks) -->
{%- assign slide_count = 0 -%}
{%- for b in section.blocks -%}{%- if b.type == 'slide' -%}{%- assign slide_count = slide_count | plus: 1 -%}{%- endif -%}{%- endfor -%}
<section class="hero">
  <div class="hero-track" id="heroTrack">
    {%- comment -%}Hardcoded asset banners — images bundled in theme assets{%- endcomment -%}
    {%- assign _slides = 'banner-slide-1.png|/collections/frontpage|Shop New Arrivals →|/collections/all|Explore All,,banner-slide-2.png|/collections/sale|Shop the Sale →||,,banner-slide-3.png|/collections/best-seller|Shop Now →||,,banner-slide-4.png|/collections/all|Shop All →||,,banner-slide-5.png|/collections/all|Explore 1500+ Styles →||,,banner-slide-6.png|/collections/bracelets|Shop Bracelets →||,,banner-slide-7.png|/collections/zodiac-pendants|Shop Zodiac →||' | split: ',,' -%}
    {%- for _s in _slides -%}
      {%- assign _sp = _s | split: '|' -%}
      {%- assign _mob = _sp[5] | default: _sp[0] -%}
      <div class="hero-slide">
        <a href="{{ _sp[1] }}" class="hero-link" aria-label="Shop Tribal Zone">
          <img class="hero-img hero-img-d" src="{{ _sp[0] | asset_url }}" alt="Tribal Zone Banner" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"/>
          <img class="hero-img hero-img-m" src="{{ _mob | asset_url }}" alt="Tribal Zone Banner" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"/>
        </a>
      </div>
    {%- endfor -%}
  </div>
  <button class="hero-arr hero-prev" onclick="heroMove(-1)"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg></button>
  <button class="hero-arr hero-next" onclick="heroMove(1)"><svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg></button>
  <div class="hero-dots" id="heroDots">
    <div class="hero-dot on" onclick="heroGo(0)"></div><div class="hero-dot" onclick="heroGo(1)"></div><div class="hero-dot" onclick="heroGo(2)"></div><div class="hero-dot" onclick="heroGo(3)"></div><div class="hero-dot" onclick="heroGo(4)"></div><div class="hero-dot" onclick="heroGo(5)"></div><div class="hero-dot" onclick="heroGo(6)"></div>
  </div>
</section>


