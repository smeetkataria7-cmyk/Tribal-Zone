<div class="cat-tiles-wrap">
  <div class="cat-tiles">
    {%- if cat_count > 0 -%}
      {%- for block in section.blocks -%}{%- if block.type == 'category' -%}
      <a href="{{ block.settings.link }}" class="cat-tile" {{ block.shopify_attributes }}><div class="cat-tile-img"{% if block.settings.is_sale %} style="border-color:var(--red)"{% endif %}><img src="{% if block.settings.image %}{{ block.settings.image | image_url: width: 300 }}{% else %}{{ block.settings.image_url }}{% endif %}" alt="{{ block.settings.label }}"/></div><div class="cat-tile-label"{% if block.settings.is_sale %} style="color:var(--red)"{% endif %}>{{ block.settings.label }}</div></a>
      {%- endif -%}{%- endfor -%}
    {%- else -%}
