{% schema %}
{
  "name": "TribalZone Homepage",
  "class": "index-section",
  "max_blocks": 50,
  "settings": [
    { "type": "header", "content": "Pink scrolling strip (marquee)" },
    { "type": "text", "id": "marquee_1", "label": "Marquee text 1", "default": "Handcrafted since 2003" },
    { "type": "text", "id": "marquee_2", "label": "Marquee text 2", "default": "Skin-safe & Anti-tarnish" },
    { "type": "text", "id": "marquee_3", "label": "Marquee text 3", "default": "Free shipping over ₹999" },
    { "type": "text", "id": "marquee_4", "label": "Marquee text 4", "default": "Cash on Delivery available" },
    { "type": "text", "id": "marquee_5", "label": "Marquee text 5", "default": "2000+ styles to choose from" },
    { "type": "text", "id": "marquee_6", "label": "Marquee text 6 (optional)", "default": "" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero slide (banner)",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image (upload here to change)" },
        { "type": "text", "id": "image_url", "label": "…or image URL (fallback)" },
        { "type": "text", "id": "eyebrow", "label": "Small label (top)" },
        { "type": "text", "id": "heading_1", "label": "Heading line 1" },
        { "type": "text", "id": "heading_em", "label": "Heading line 2 (italic pink)" },
        { "type": "text", "id": "heading_2", "label": "Heading line 3" },
        { "type": "textarea", "id": "desc", "label": "Description" },
        { "type": "text", "id": "btn1_label", "label": "Button 1 text" },
        { "type": "url", "id": "btn1_link", "label": "Button 1 link" },
        { "type": "text", "id": "btn2_label", "label": "Button 2 text" },
        { "type": "url", "id": "btn2_link", "label": "Button 2 link" }
      ]
    },
    {
      "type": "category",
      "name": "Category circle",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (upload here to change)" },
        { "type": "text", "id": "image_url", "label": "…or image URL (fallback)" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "checkbox", "id": "is_sale", "label": "Sale style (red)", "default": false }
      ]
    },
    {
      "type": "occasion",
      "name": "Occasion card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (upload here to change)" },
        { "type": "text", "id": "image_url", "label": "…or image URL (fallback)" },
        { "type": "text", "id": "label", "label": "Label" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "insta",
      "name": "Instagram photo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (upload here to change)" },
        { "type": "text", "id": "image_url", "label": "…or image URL (fallback)" },
        { "type": "url", "id": "link", "label": "Link (Instagram post)" }
      ]
    }
  ],
  "presets": [{ "name": "TribalZone Homepage" }]
}
{% endschema %}
