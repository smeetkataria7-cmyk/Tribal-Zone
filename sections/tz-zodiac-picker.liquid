<!-- SHOP BY ZODIAC PICKER -->
<section class="tz-zodiac-pick">
  <div class="tz-zp-inner">
    <span class="tz-zp-eyebrow">Celestial Collection</span>
    <h2 class="tz-zp-title">Shop by <em>Zodiac</em></h2>
    <p class="tz-zp-sub">Find a pendant for your star sign &mdash; the perfect personalised gift.</p>
    <div class="tz-zp-grid">
      {% assign zodiac_collection = collections['zodiac-pendants'] %}
      {% for product in zodiac_collection.products limit:12 %}
        <a href="{{ product.url }}" class="tz-zp-card">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | img_url: '240x240' }}" alt="{{ product.title }}" class="tz-zp-img"/>
          {% endif %}
          <span class="tz-zp-pname">{{ product.title }}</span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{ "name": "Zodiac Picker", "class": "index-section", "settings": [], "presets": [{ "name": "Zodiac Picker" }] }
{% endschema %}
