<!-- HERO CAROUSEL -->
<section class="hero">
  <div class="hero-track" id="heroTrack">

    <div class="hero-slide">
      <div class="hero-bg" style="background-image:url('https://cdn.shopify.com/s/files/1/0301/2793/files/TZHC4351-5_1.jpg?v=1780742553')"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div class="hero-eyebrow">New Arrivals — 2024</div>
        <h1 class="hero-h1">Elevate Your<br/><em>Everyday</em><br/>with Jewellery</h1>
        <p class="hero-desc">Handcrafted fashion accessories blending Indian tradition with modern elegance — since 2003.</p>
        <div class="hero-btns">
          <a href="/collections/earrings" class="btn-fill">Shop New Arrivals →</a>
          <a href="/collections/earrings" class="btn-outline-w">Explore All</a>
        </div>
      </div>
    </div>

    <div class="hero-slide">
      <div class="hero-bg" style="background-image:url('https://cdn.shopify.com/s/files/1/0301/2793/files/Creative_e0be92f9-4e21-488f-9628-99cdf0fd33d8.jpg?v=1781088637')"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div class="hero-eyebrow">Limited Time Offer</div>
        <h1 class="hero-h1">Up to<br/><em>50% Off</em><br/>Sale is Live</h1>
        <p class="hero-desc">Shop our biggest sale of the season. Stunning earrings, necklaces &amp; more at unbeatable prices.</p>
        <div class="hero-btns">
          <a href="/collections/sale" class="btn-fill">Shop the Sale →</a>
        </div>
      </div>
    </div>

    <div class="hero-slide">
      <div class="hero-bg" style="background-image:url('https://cdn.shopify.com/s/files/1/0301/2793/files/Creative_46df76f1-5aa8-44cb-9404-46bdeed4d4a1.jpg?v=1781081928')"></div>
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <div class="hero-eyebrow">Celestial Collection</div>
        <h1 class="hero-h1">Wear Your<br/><em>Zodiac</em><br/>Story</h1>
        <p class="hero-desc">Meaningful pendants for all 12 star signs. The perfect personalised gift for someone special.</p>
        <div class="hero-btns">
          <a href="/collections/zodiac-pendants" class="btn-fill">Shop Zodiac →</a>
        </div>
      </div>
    </div>

  </div>
  <button class="hero-arr hero-prev" onclick="heroMove(-1)">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m15 18-6-6 6-6"/></svg>
  </button>
  <button class="hero-arr hero-next" onclick="heroMove(1)">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
  </button>
  <div class="hero-dots" id="heroDots">
    <div class="hero-dot on" onclick="heroGo(0)"></div>
    <div class="hero-dot" onclick="heroGo(1)"></div>
    <div class="hero-dot" onclick="heroGo(2)"></div>
  </div>
</section>

{% schema %}
{ "name": "Hero Carousel", "class": "index-section", "settings": [], "presets": [{ "name": "Hero Carousel" }] }
{% endschema %}
